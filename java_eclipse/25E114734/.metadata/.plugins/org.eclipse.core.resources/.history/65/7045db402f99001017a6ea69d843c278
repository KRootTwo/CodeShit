package question_09b;

public class Main {
	public static void main(String[] args) {
		int a = 20 ;
		int b = 30 ;
		int c = 10 ;
		
		System.out.println("A = " + a);
		System.out.println("B = " + b);
		System.out.println("C = " + c);
		
		System.out.println("Swapping numbers...");
		
		a = a+b+c ;
		c = a-b-c ;
		b = a-b-c ;
		
		
		System.out.println("A = " + a);
		System.out.println("B = " + b);
		System.out.println("C = " + c);
	}

}
