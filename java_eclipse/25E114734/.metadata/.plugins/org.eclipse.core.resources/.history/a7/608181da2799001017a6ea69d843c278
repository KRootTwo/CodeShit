package question_05;
import java.math.*;
import java.util.Scanner;


public class Main {
	public static void main(String[] args) {
		Scanner blud = new Scanner(System.in);
		System.out.print("Radius of circle: ");
		int radius = blud.nextInt();
		System.out.println("Perimeter of the circle is: " + radius*Math.PI*2);
		System.out.println("Perimeter of the circle is: " + Math.pow(radius,2));
	}

}
