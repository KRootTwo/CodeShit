	public static int factSum(int n) {
		int sum = 0;
		for (int i = 1; i < n; i++) {
			if (n % i == 0) sum += i;
		}
		return sum;
	}
	public static boolean perfect(int n) {
		boolean p = false;
		if (n == factSum(n)) p = true;
		return p;
	}
	public static int gcd(int x, int y) {
		while (y != 0) {
			int r = x % y;
			x = y;
			y = r;
		}
		return x;
	}
	public static boolean isPal(String o) {
		String r = o.toLowerCase();
		int s = 0, e = r.length() - 1;
		while (s < e) {
			if (r.charAt(s) != r.charAt(e)) {
				return false;
			}
			s++; e--;
		}
		return true;
	}
	public static boolean amic(int a, int b) {
		if (factSum(a) == b && factSum(b) == a) return true;
		return false;
	}
	public static void pat6c(int n) {
		for (int i = 1; i <= n; i++) {
			for (int j = i; j <= n - 1; j++) {
				System.out.print("  ");
			}
			for (int k = 1; k <= i; k++) {
				System.out.print(i +" ");
			}
			System.out.println();
		}
	}
	public static void ser(int n) {
		for (int i = 1; i <= n; i++) {
			System.out.print("(");
			for (int j = 1; j <= i; j++) {
				System.out.print(j);
				if (j < i) System.out.print(" + ");
			}
			System.out.print(")");
			if (i < n) System.out.print(" + ");
		}
	}
	public static int occ(String f, char c) {
		c = Character.toLowerCase(c);
		int ct = 0;
		for (int i = 0; i < f.length() - 1; i++) {
			if (Character.toLowerCase(f.charAt(i)) == c) ct++;
		}
		return ct;
	}
