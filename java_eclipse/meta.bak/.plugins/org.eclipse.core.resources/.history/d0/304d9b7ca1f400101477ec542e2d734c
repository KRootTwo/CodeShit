	public static int[] elmDupes(int [] arr) {
		int temp[] = new int [arr.length];
		int c = 0;
		for (int i = 0; i < arr.length; i++) {
			boolean dup = false;
			for (int j = 0; j < i; j++) {
				if (arr[i] == arr[j]) {
					dup = true;
					break;
				}
			}
			if (!dup) {
				temp[c] = arr[i];
				c++;
			}
		}
		int rex[] = new int[c];
		System.arraycopy(temp, 0, rex, 0, c);
		return rex;
	}
	public static int lgst(int[] arr) {
		int l = arr[0];
		for (int i = 1; i < arr.length; i++) {
			if (arr[i] > l) l = arr[i];
		}
		return l;
	}
	public static int slgst(int [] arr) {
		int l = arr[0], sl = Integer.MIN_VALUE;
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] > l) {
				sl = l;
				l = arr[i];
			}
			if (arr[i] > sl && arr[i] < l) {
				sl = arr[i];
			}
		}
		return sl;
	}
	public static int tlgst(int [] arr) {
		int l = arr[0], sl = Integer.MIN_VALUE,tl = Integer.MIN_VALUE;
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] > l) {
				tl = sl;
				sl = l;
				l = arr[i];
			}
			if (arr[i] > sl && arr[i] < l) {
				sl = arr[i];
			}
			if (arr[i] > tl && arr[i] < sl) {
				tl = arr[i];
			}
		}
		return tl;
	}
	public static void mvZeroToFrontNoPrsv(int [] arr) {
		int c = 0, temp = 0;
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] == 0) {
				temp = arr[i];
				arr[i] = arr[c];
				arr[c] = temp;
				c++;
			}
		}
	}
	public static void mvZeroToFront(int [] arr) {
		int temp[] = new int [arr.length];
		int id = 0;
		for (int i : arr) 
			if (i == 0) temp[id++] = 0;
		for (int i : arr) 
			if (i != 0) temp[id++] = i;
		System.arraycopy(temp, 0, arr, 0, arr.length);
	}
	public static void mvZeroToEnd(int [] arr) {
		int temp[] = new int[arr.length], c = 0, d = arr.length - 1;
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] != 0) {
				arr[i] = temp[c];
				c++;
			}
			else if (arr[i] == 0) {
				arr[d--] = 0;
			}
		}
//		for (int i = 0; i < arr.length - c - 1;)
		System.arraycopy(temp, 0, arr, 0, c);
	}
	public static void revArr(int [] arr) {
		int s = 0, e = arr.length - 1;
		while (s < e) {
			int temp = arr[s];
			arr[s] = arr[e];
			arr[e] = temp;
			s++; e--;
		}
	}
	public static void bubbleSort(int [] arr) {
		for (int i = 0; i < arr.length - 1; i++) {
			for (int j = 0; j < arr.length - i - 1; j++) {
				if (arr[j] > arr[j + 1]) {
					int temp = arr[j];
					arr[j] = arr[j + 1];
					arr[j + 1] = temp;
				}
			}
		}
	}
	public static void linearSearch(int [] arr, int e) {
		int loc = -1;
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] == e) {
				loc = i;
				break;
			}
		}
		if (loc != -1) System.out.println("Element "+ e +" is at index "+ loc);
		else if (loc == -1) System.out.println("Element is not in array.");
	}
	public static void binarySearch(int [] arr, int n) {
		int mid = -1,s = 0, e = arr.length - 1;
		while (s <= e) {
			mid = (s + e) / 2;
			if (arr[mid] == n) {
				System.out.println("Element "+ n +" is at index "+ mid);
				break;
			}
			else if (arr[mid] > n)
				e = mid - 1;
			else 
				s = mid + 1;
		}
		if (mid == -1) System.out.println("Element is not in array.");
	}
