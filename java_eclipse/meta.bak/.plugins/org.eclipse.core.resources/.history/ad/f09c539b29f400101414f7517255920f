	public static int lgst(int[] arr) {
		int l = arr[0];
		for (int i = 1; i < arr.length; i++) {
			if (arr[i] > l) l = arr[i];
		}
		return l;
	}
	public static int slgst(int[] arr) {
		int l = arr[0], sl = arr[0];
		for (int i = 1; i < arr.length; i++) {
			if (arr[i] > l) {
				sl = l;
				l = arr[i];
			}
			else if (arr[i] > sl && arr[i] != l) {
				sl = arr[i];
			}
		}
		return sl;
	}
