	public static int[] elmDupes(int [] arr) {
		int temp[] = new int [arr.length];
		int c = 0;
		for (int i = 0; i < arr.length; i++) {
			boolean dup = false;
			for (int j = 0; j < i; j++) {
				if (arr[i] == arr[j]) {
					dup = true;
					break;
				}
			}
			if (!dup) {
				temp[c] = arr[i];
				c++;
			}
		}
		int rex[] = new int[c];
		System.arraycopy(temp, 0, rex, 0, c);
		return rex;
	}
