	public static int findMax(int [] arr) {
		int m = arr[0];
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] > m) m = arr[i];
		}
		return m;
	}
	public static int secMax(int [] arr) {
		int m = arr[0], s = Integer.MIN_VALUE;
		for (int i = 0; i < arr.length; i++) {
			if (arr[i] > m) {
				s = m;
				m = arr[i];
			}
			else if (arr[i] < m && arr[i] > s) 
				s = arr[i];
		}
		return s;
	}
